{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["lastUpdated", "providers"],
  "additionalProperties": false,
  "properties": {
    "lastUpdated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date in YYYY-MM-DD format"
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "url",
          "location",
          "freePlan",
          "freeLimits",
          "payAsYouGo",
          "plans",
          "marketingAllowed",
          "verificationNeeded",
          "domainLimit",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "pattern": "^https?://.+"
          },
          "location": {
            "type": "string",
            "enum": ["EU", "US", "UK", "CA", "Global"]
          },
          "freePlan": {
            "type": "boolean"
          },
          "freeLimits": {
            "type": ["string", "null"]
          },
          "payAsYouGo": {
            "type": "boolean"
          },
          "plans": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["volume", "costPerMonth", "costPerEmail", "extra"],
              "additionalProperties": false,
              "properties": {
                "volume": {
                  "type": "number",
                  "minimum": 0
                },
                "costPerMonth": {
                  "type": "number",
                  "minimum": 0
                },
                "costPerEmail": {
                  "type": "number",
                  "minimum": 0
                },
                "billingModel": {
                  "type": "string",
                  "enum": ["subscription", "metered", "prepaid_bundle"]
                },
                "extra": {
                  "oneOf": [
                    {
                      "type": "null"
                    },
                    {
                      "type": "object",
                      "required": ["blockSize", "costPerBlock", "costPerEmail"],
                      "additionalProperties": false,
                      "properties": {
                        "blockSize": {
                          "type": "number",
                          "minimum": 0
                        },
                        "costPerBlock": {
                          "type": "number",
                          "minimum": 0
                        },
                        "costPerEmail": {
                          "type": "number",
                          "minimum": 0
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "marketingAllowed": {
            "type": ["boolean", "null"]
          },
          "verificationNeeded": {
            "type": ["boolean", "null"]
          },
          "domainLimit": {
            "type": ["number", "null"],
            "minimum": 1
          },
          "notes": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
